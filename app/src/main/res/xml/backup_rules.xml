<full-backup-content>
    <!-- Include receipt images and general app data. -->
    <!-- S3: only general app prefs are backed up; billing prefs (receiptvault_billing.xml)
         are deliberately omitted from this allow-list so entitlement state comes from
         Google Play, not device backup. -->
    <include domain="file" path="receipts/" />
    <include domain="sharedpref" path="receiptvault.xml" />
</full-backup-content>
